{
  "name": "oklch-badge-colors",
  "version": "1.0.2",
  "description": "Deterministic OKLCH color generator for badges with dark mode and WCAG contrast correction",
  "repository": {
    "type": "git",
    "url": "https://github.com/angedell/oklch-badge-colors.git"
  },
  "bugs": {
    "url": "https://github.com/angedell/oklch-badge-colors/issues"
  },
  "homepage": "https://github.com/angedell/oklch-badge-colors#readme",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "oklch",
    "color",
    "badge",
    "design-system",
    "dark-mode",
    "wcag",
    "intentui",
    "ui"
  ],
  "license": "MIT",
  "author": "Angelo Dell Acqua"
}
